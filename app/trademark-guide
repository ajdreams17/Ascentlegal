<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The 7 Mistakes That Kill New Trademarks — Ascent Legal</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:      #1a2438;
    --navy-mid:  #2a3d5c;
    --navy-deep: #0f1623;
    --orange:    #e8722a;
    --orange-lt: #f08c4a;
    --cream:     #f5f2ed;
    --white:     #ffffff;
    --muted:     #6b7280;
    --rule:      #e2e8f0;
    --blue-grad: #3b6cb7;
  }

  *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Outfit', sans-serif;
    background: var(--navy-deep);
    color: var(--white);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top:0; left:0; right:0; z-index:100;
    display: flex; align-items:center; justify-content:space-between;
    padding: 16px 60px;
    background: rgba(15,22,35,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(232,114,42,0.12);
  }
  .nav-logo img { height: 36px; width: auto; display:block; }
  .nav-right { display:flex; align-items:center; gap:28px; }
  .nav-tag {
    font-size: 10px; font-weight:600; letter-spacing:.22em;
    text-transform:uppercase; color: rgba(255,255,255,0.35);
  }
  .nav-btn {
    font-family:'Outfit',sans-serif; font-size:11px; font-weight:600;
    letter-spacing:.14em; text-transform:uppercase;
    color: var(--navy-deep); background: var(--orange);
    border:none; padding:10px 22px; border-radius:2px;
    cursor:pointer; text-decoration:none;
    transition: background .2s, transform .15s;
  }
  .nav-btn:hover { background: var(--orange-lt); transform:translateY(-1px); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    padding-top: 70px;
    position: relative;
    overflow: hidden;
  }

  /* Geometric background */
  .hero::before {
    content:'';
    position:absolute; inset:0;
    background:
      linear-gradient(135deg, #0f1623 0%, #1a2438 50%, #0f1623 100%);
    z-index:0;
  }
  .hero-geo {
    position:absolute; inset:0; z-index:0; overflow:hidden;
  }
  .hero-geo svg { position:absolute; right:-80px; top:60px; opacity:.06; }

  /* Left col */
  .hero-left {
    position:relative; z-index:2;
    padding: 88px 64px 80px;
    display:flex; flex-direction:column; justify-content:center;
  }
  .hero-left::after {
    content:'';
    position:absolute; top:0; right:-1px; bottom:0;
    width:1px;
    background: linear-gradient(to bottom,
      transparent, rgba(232,114,42,0.3) 30%, rgba(232,114,42,0.3) 70%, transparent);
  }

  .eyebrow {
    display:inline-flex; align-items:center; gap:10px;
    margin-bottom:26px;
    opacity:0; animation: fadeUp .6s ease forwards .1s;
  }
  .eyebrow-line { width:28px; height:1.5px; background:var(--orange); }
  .eyebrow span {
    font-size:10px; font-weight:600; letter-spacing:.28em;
    text-transform:uppercase; color:var(--orange);
  }

  .hero-title {
    font-family:'Cormorant Garamond', serif;
    font-size: clamp(40px, 4.5vw, 64px);
    font-weight:700; line-height:1.04;
    color:var(--white);
    margin-bottom:10px;
    opacity:0; animation: fadeUp .7s ease forwards .25s;
  }
  .hero-title em {
    font-style:italic; color:var(--orange);
    display:block;
  }

  .hero-sub-label {
    font-size:10px; font-weight:600; letter-spacing:.2em;
    text-transform:uppercase; color:rgba(255,255,255,.28);
    margin-bottom:22px;
    opacity:0; animation: fadeUp .5s ease forwards .38s;
  }

  .hero-desc {
    font-size:16px; font-weight:300; line-height:1.78;
    color:rgba(255,255,255,.62); max-width:420px;
    margin-bottom:40px;
    opacity:0; animation: fadeUp .7s ease forwards .48s;
  }
  .hero-desc strong { color:rgba(255,255,255,.9); font-weight:500; }

  /* ── KIT FORM ZONE ── */
  .form-zone {
    opacity:0; animation: fadeUp .7s ease forwards .6s;
  }

  /* This wrapper styles Kit's injected form */
  .kit-form-wrapper {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 4px;
    padding: 28px;
  }
  .kit-form-wrapper p {
    font-size:12px; font-weight:500; letter-spacing:.14em;
    text-transform:uppercase; color:rgba(255,255,255,.4);
    margin-bottom:16px;
  }

  /* Override Kit form inputs */
  .kit-form-wrapper input[type=text],
  .kit-form-wrapper input[type=email],
  .formkit-input {
    width:100% !important;
    background: rgba(255,255,255,.07) !important;
    border: 1px solid rgba(255,255,255,.14) !important;
    color: var(--white) !important;
    font-family:'Outfit',sans-serif !important;
    font-size:14px !important;
    padding: 14px 18px !important;
    border-radius:3px !important;
    margin-bottom:10px !important;
    outline:none !important;
  }
  .formkit-submit, .kit-form-wrapper button[type=submit] {
    width:100% !important;
    background: var(--orange) !important;
    color: var(--navy-deep) !important;
    font-family:'Outfit',sans-serif !important;
    font-size:12px !important;
    font-weight:700 !important;
    letter-spacing:.14em !important;
    text-transform:uppercase !important;
    border:none !important;
    padding:16px !important;
    border-radius:3px !important;
    cursor:pointer !important;
    margin-top:4px !important;
    transition: background .2s !important;
  }
  .formkit-submit:hover { background: var(--orange-lt) !important; }
  .formkit-guarantee { color:rgba(255,255,255,.28) !important; font-size:11px !important; }

  .form-trust {
    display:flex; gap:18px; margin-top:14px; flex-wrap:wrap;
  }
  .trust-pill {
    display:flex; align-items:center; gap:6px;
    font-size:11px; color:rgba(255,255,255,.32);
  }
  .trust-pill::before {
    content:''; width:5px; height:5px; border-radius:50%;
    background:rgba(232,114,42,.5); flex-shrink:0;
  }

  /* Right col */
  .hero-right {
    position:relative; z-index:2;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    padding: 80px 50px 80px 72px; gap:36px;
  }

  /* Book mockup */
  .book-wrap { position:relative; }
  .book {
    width:252px;
    background: var(--navy-mid);
    border-radius:3px 10px 10px 3px;
    padding:38px 30px 34px;
    box-shadow:
      -5px 0 0 #111,
      -10px 0 0 rgba(0,0,0,.18),
      28px 28px 70px rgba(0,0,0,.35),
      0 0 0 1px rgba(255,255,255,.04);
    position:relative; overflow:hidden;
  }
  .book::before {
    content:''; position:absolute; left:0; top:0; bottom:0; width:5px;
    background:linear-gradient(to right,#0d1420,#1a2438);
  }
  .book-watermark {
    position:absolute; font-family:'Cormorant Garamond',serif;
    font-size:100px; font-weight:700;
    color:rgba(232,114,42,.06); right:8px; top:16px; line-height:1;
  }
  .book-seal {
    width:44px; height:44px; border-radius:50%;
    border:1.5px solid rgba(232,114,42,.45);
    display:flex; align-items:center; justify-content:center;
    margin-bottom:18px;
  }
  .book-seal svg { width:20px; height:20px; fill:var(--orange); }
  .book-label {
    font-size:8.5px; font-weight:600; letter-spacing:.26em;
    text-transform:uppercase; color:var(--orange); margin-bottom:10px;
  }
  .book-title {
    font-family:'Cormorant Garamond',serif;
    font-size:19px; font-weight:700; line-height:1.28;
    color:var(--white); margin-bottom:16px;
  }
  .book-title em { color:var(--orange-lt); font-style:italic; display:block; }
  .book-rule {
    height:1px; width:65%;
    background:linear-gradient(to right, rgba(232,114,42,.5), transparent);
    margin-bottom:14px;
  }
  .book-firm {
    font-size:9.5px; letter-spacing:.16em; text-transform:uppercase;
    color:rgba(255,255,255,.28);
  }
  .free-badge {
    position:absolute; top:-16px; right:-16px;
    width:66px; height:66px; border-radius:50%;
    background:var(--orange);
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    box-shadow:0 6px 22px rgba(232,114,42,.42);
    animation: spin-slow 12s linear infinite;
  }
  .free-badge span {
    font-size:9px; font-weight:700; color:white;
    text-transform:uppercase; letter-spacing:.06em;
    text-align:center; line-height:1.4;
  }
  @keyframes spin-slow { to { transform:rotate(360deg); } }

  /* Who it's for */
  .for-block { width:100%; max-width:252px; }
  .for-label {
    font-size:9.5px; font-weight:600; letter-spacing:.22em;
    text-transform:uppercase; color:rgba(255,255,255,.3);
    margin-bottom:12px;
  }
  .for-item {
    display:flex; align-items:center; gap:10px;
    padding:9px 0; border-bottom:1px solid rgba(255,255,255,.06);
    font-size:13px; color:rgba(255,255,255,.68);
  }
  .for-item:last-child { border-bottom:none; }
  .for-dot { width:5px; height:5px; border-radius:50%; background:var(--orange); flex-shrink:0; }

  /* ── WHAT'S INSIDE ── */
  .inside {
    background: var(--cream);
    padding: 100px 60px;
  }
  .section-hdr { text-align:center; max-width:560px; margin:0 auto 64px; }
  .section-eye {
    font-size:9.5px; font-weight:600; letter-spacing:.26em;
    text-transform:uppercase; color:var(--orange); margin-bottom:12px;
  }
  .section-title {
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(26px,3vw,40px); font-weight:700; line-height:1.15;
    color:var(--navy); margin-bottom:14px;
  }
  .section-sub { font-size:14.5px; color:var(--muted); line-height:1.72; }

  .mistakes-grid {
    display:grid; grid-template-columns:repeat(auto-fill,minmax(285px,1fr));
    gap:3px; max-width:1060px; margin:0 auto;
  }
  .mistake-card {
    background:white; padding:32px 28px;
    position:relative; overflow:hidden;
    transition: transform .22s, box-shadow .22s;
    cursor:default;
  }
  .mistake-card:hover { transform:translateY(-4px); box-shadow:0 14px 44px rgba(0,0,0,.1); z-index:1; }
  .mistake-card::after {
    content:''; position:absolute; bottom:0; left:0; right:0; height:2px;
    background:linear-gradient(to right,var(--orange),var(--orange-lt));
    transform:scaleX(0); transform-origin:left; transition:transform .3s;
  }
  .mistake-card:hover::after { transform:scaleX(1); }
  .mistake-num {
    font-family:'Cormorant Garamond',serif;
    font-size:46px; font-weight:700; line-height:1;
    color:rgba(232,114,42,.1); margin-bottom:2px;
  }
  .mistake-name {
    font-family:'Cormorant Garamond',serif;
    font-size:18px; font-weight:700; line-height:1.3;
    color:var(--navy); margin-bottom:8px;
  }
  .mistake-desc { font-size:13px; color:var(--muted); line-height:1.68; }
  .mistake-tag {
    display:inline-block; margin-top:12px;
    font-size:9px; font-weight:600; letter-spacing:.16em; text-transform:uppercase;
    color:#c0392b; background:rgba(192,57,43,.07);
    padding:3px 9px; border-radius:2px;
  }

  /* ── RISK SCORE TEASER ── */
  .risk-teaser {
    background: var(--navy);
    padding: 80px 60px;
    display:grid; grid-template-columns:1fr 1fr; gap:70px;
    max-width:1060px; margin:0 auto;
  }
  .risk-left { display:flex; flex-direction:column; justify-content:center; }
  .risk-label {
    font-size:9.5px; font-weight:600; letter-spacing:.26em;
    text-transform:uppercase; color:var(--orange); margin-bottom:14px;
  }
  .risk-title {
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(24px,2.8vw,36px); font-weight:700; line-height:1.18;
    color:var(--white); margin-bottom:16px;
  }
  .risk-body { font-size:14.5px; font-weight:300; line-height:1.78; color:rgba(255,255,255,.58); }

  .risk-bands { display:flex; flex-direction:column; gap:3px; }
  .risk-band {
    display:grid; grid-template-columns:120px 1fr;
    align-items:center;
  }
  .band-score {
    padding:12px 16px;
    font-size:11px; font-weight:700; letter-spacing:.06em;
    color:white; line-height:1.3;
  }
  .band-desc { padding:12px 18px; background:rgba(255,255,255,.04); font-size:12.5px; color:rgba(255,255,255,.6); line-height:1.5; }

  /* ── STATS ── */
  .stats-bar {
    background:var(--navy-deep);
    padding:64px 60px;
    display:flex; align-items:center; justify-content:center;
    gap:64px; flex-wrap:wrap;
  }
  .stat { text-align:center; }
  .stat-num {
    font-family:'Cormorant Garamond',serif;
    font-size:50px; font-weight:700; line-height:1;
    color:var(--orange-lt); margin-bottom:6px;
  }
  .stat-lbl { font-size:11px; color:rgba(255,255,255,.38); letter-spacing:.1em; text-transform:uppercase; line-height:1.5; }
  .vdiv { width:1px; height:48px; background:rgba(255,255,255,.07); }

  /* ── BOTTOM CTA ── */
  .bottom-cta {
    background:var(--cream); padding:100px 60px; text-align:center;
    position:relative; overflow:hidden;
  }
  .bottom-cta::before {
    content:'TM';
    position:absolute; font-family:'Cormorant Garamond',serif;
    font-size:360px; font-weight:700; color:rgba(26,36,56,.05);
    top:50%; left:50%; transform:translate(-50%,-50%);
    pointer-events:none; letter-spacing:-.04em;
  }
  .cta-eye { font-size:9.5px; font-weight:600; letter-spacing:.26em; text-transform:uppercase; color:var(--orange); margin-bottom:16px; }
  .cta-title {
    font-family:'Cormorant Garamond',serif;
    font-size:clamp(26px,3.5vw,46px); font-weight:700; line-height:1.14;
    color:var(--navy); margin-bottom:16px; position:relative;
  }
  .cta-sub {
    font-size:15px; font-weight:300; color:var(--muted);
    max-width:480px; margin:0 auto 40px; line-height:1.76; position:relative;
  }

  /* Kit form in bottom CTA */
  .cta-kit-wrap {
    max-width:460px; margin:0 auto; position:relative;
  }
  .cta-kit-wrap .formkit-form { background:transparent !important; }
  .cta-kit-wrap .formkit-input {
    background:white !important;
    border:1.5px solid var(--rule) !important;
    color:var(--navy-deep) !important;
    font-family:'Outfit',sans-serif !important;
    font-size:14px !important; padding:15px 18px !important;
    border-radius:3px !important; margin-bottom:10px !important;
    width:100% !important;
  }

  /* ── FOOTER ── */
  footer {
    background:#080d15;
    padding:32px 60px;
    display:flex; align-items:center; justify-content:space-between;
    flex-wrap:wrap; gap:16px;
    border-top:1px solid rgba(232,114,42,.1);
  }
  .footer-logo { display:flex; align-items:center; gap:10px; }
  .footer-logo img { height:28px; width:auto; }
  .footer-note { font-size:10.5px; color:rgba(255,255,255,.2); letter-spacing:.04em; }
  .footer-links { display:flex; gap:22px; }
  .footer-links a { font-size:10.5px; color:rgba(255,255,255,.28); text-decoration:none; letter-spacing:.08em; text-transform:uppercase; transition:color .2s; }
  .footer-links a:hover { color:var(--orange); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity:0; transform:translateY(18px); }
    to   { opacity:1; transform:translateY(0); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width:900px) {
    nav { padding:14px 24px; }
    .nav-tag { display:none; }
    .hero { grid-template-columns:1fr; }
    .hero-left { padding:80px 28px 52px; }
    .hero-left::after { display:none; }
    .hero-right { padding:40px 28px 70px; }
    .inside { padding:72px 24px; }
    .risk-teaser { grid-template-columns:1fr; padding:60px 24px; gap:40px; }
    .stats-bar { gap:32px; padding:50px 24px; }
    .bottom-cta { padding:72px 24px; }
    footer { padding:28px 24px; flex-direction:column; align-items:flex-start; }
    .vdiv { display:none; }
  }
</style>
</head>
